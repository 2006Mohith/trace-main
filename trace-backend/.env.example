# TRACE Configuration Environment Variables
# Copy this file to .env and fill in the values. Never commit the actual .env file.

# Session and Auth security (Generate 64-char hex strings)
SECRET_KEY=94e77229712aefbc6c778adfe08c7e7bdfa35b67e8902cd56037a38fe49a756b
REFRESH_SECRET_KEY=a7d3bf6cf8a2301cb4d80a1562bcfde8c0a87693d2568e0dca3fbc7c0147986b

# Database and Backup Encryption Keys (32-character random key or Fernet-compatible key)
DB_ENCRYPTION_KEY=my_secure_db_passphrase_key_12345
BACKUP_ENCRYPTION_KEY=my_secure_backup_fernet_key_12345
FIELD_ENCRYPTION_KEY=my_secure_field_fernet_key_12345

# Database config
# SQLite SQLCipher URL structure: sqlite+pysqlcipher://:key@/trace.db
DATABASE_URL=sqlite:///./trace.db
# DATABASE_REPLICA_URL=sqlite:///./trace_replica.db

# Cache and Revocation database (Redis)
REDIS_URL=redis://localhost:6379/0

# LLM integration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Network security
ALLOWED_ORIGINS=http://localhost:5173
ADMIN_IP_WHITELIST=127.0.0.1/32,10.0.0.0/8

# Operations & Storage config
ENVIRONMENT=development
LOG_LEVEL=INFO
FACE_REGISTRY_PATH=storage/face_registry
MAX_UPLOAD_SIZE_MB=100
